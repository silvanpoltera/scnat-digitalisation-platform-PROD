NODE_ENV=production
PORT=3001

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS — the public URL of your frontend (no trailing slash)
CORS_ORIGIN=https://platform.poltis.ch

# Cookie — MUST be true in production (requires HTTPS)
COOKIE_SECURE=true

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys --json
# Required for push notifications. Without these, the /api/push endpoints return 503.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@platform.poltis.ch
