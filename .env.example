NODE_ENV=production
PORT=3001

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS — the public URL of your frontend (no trailing slash)
CORS_ORIGIN=https://platform.poltis.ch

# Cookie — MUST be true in production (requires HTTPS)
COOKIE_SECURE=true
